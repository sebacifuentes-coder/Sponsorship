# =============================================================================
# .env.example — Copiloto de Patrocinio Deportivo
# =============================================================================
# AD-6: los secretos viven SOLO en variables de entorno, nunca en el repo.
# Copia este archivo a `.env.local` y rellena los valores reales.
# `.env` y `.env.*` están ignorados por git (salvo este `.env.example`).
#
# La app corre en local sin estos valores (plano ligero, AD-1); auth/RLS y los
# proveedores se activan cuando se configuran.
# =============================================================================

# --- Supabase (auth + Postgres + RLS — AD-9) ---------------------------------
# Panel del proyecto Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo servidor — NUNCA exponer al cliente ni prefijar con NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# --- Proveedor LLM (vía Vercel AI SDK, detrás de LlmPort — AD-5) -------------
# Se usa a partir de la Historia 3.1. Elegir UNO de los proveedores.
# Azure OpenAI:
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_RESOURCE_NAME=
# o Google:
GOOGLE_GENERATIVE_AI_API_KEY=
